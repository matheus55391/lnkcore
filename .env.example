# -----------------------------------------------------------------------------
# lnkcore — production environment file (VPS)
# Copy to .env and fill in all values before running:
#   cp .env.example .env
# -----------------------------------------------------------------------------

# ---------- Docker image ---------
# Image name and tag pulled from the registry on the VPS.
# Example: myuser/lnkcore
DOCKER_IMAGE=change-me
IMAGE_TAG=latest

# ---------- App network binding ----------
# 0.0.0.0 expõe publicamente na porta 3000 (acesso via http://IP-DA-VPS:3000).
# Troque por 127.0.0.1 se for usar nginx como reverse proxy na frente do app.
APP_HOST=0.0.0.0
APP_PORT=3000

# ---------- PostgreSQL ----------
# These values are used by the postgres service in docker-compose.prod.yml.
POSTGRES_DB=lnkcore
POSTGRES_USER=lnkcore
# Use a strong, random password. E.g.: openssl rand -base64 24
POSTGRES_PASSWORD=change-me

# The app connects through the internal Docker network (service name = lnkcore-postgres).
DATABASE_URL=postgresql://lnkcore:change-me@lnkcore-postgres:5432/lnkcore?schema=public

# ---------- Better Auth ----------
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-use-at-least-32-random-chars
# Public HTTPS URL of your domain (no trailing slash).
BETTER_AUTH_URL=https://yourdomain.com

# ---------- Stripe ----------
# Use live keys in production (sk_live_... / whsec_...).
STRIPE_SECRET_KEY=sk_live_change_me
# Price ID of the PRO recurring plan in your Stripe Dashboard.
STRIPE_PRO_PRICE_ID=price_change_me
# Webhook secret for /api/stripe/webhook (from Stripe Dashboard → Webhooks).
STRIPE_WEBHOOK_SECRET=whsec_change_me

# ---------- Object storage (S3 / Cloudflare R2 / etc.) ----------
# Endpoint of your S3-compatible provider.
# Cloudflare R2 example: https://<account-id>.r2.cloudflarestorage.com
# AWS S3 example:        https://s3.<region>.amazonaws.com
S3_ENDPOINT=https://change-me
S3_REGION=us-east-1
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_BUCKET=change-me
# Set to "false" for AWS S3 or Cloudflare R2; "true" only for self-hosted MinIO.
S3_FORCE_PATH_STYLE=false
# Public base URL used by browsers to load stored files.
# Cloudflare R2 custom domain example: https://assets.yourdomain.com
S3_PUBLIC_URL=https://change-me

# ---------- Discord ----------
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/SEU_WEBHOOK