# -----------------------------------------------------------------------------
# lnkcore — example environment file
# Copy this file to `.env` and adjust the values for your environment:
#   cp .env.example .env
# -----------------------------------------------------------------------------

# ---------- Database (PostgreSQL) ----------
# Matches the docker-compose.yml defaults for local development.
DATABASE_URL="postgresql://lnkcore:lnkcore@localhost:5432/lnkcore?schema=public"

# ---------- Better Auth ----------
# Generate a strong secret (>= 32 chars). E.g.: `openssl rand -base64 32`
BETTER_AUTH_SECRET="change-me-please-use-a-strong-32-char-secret"
# Public base URL of the app (no trailing slash).
BETTER_AUTH_URL="http://localhost:3000"
# Optional: exposed to the browser so the auth client can resolve the base URL.
# NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# ---------- Object storage (MinIO / S3-compatible) ----------
# Matches the docker-compose.yml defaults for local development.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="lnkcore"
S3_SECRET_KEY="lnkcore123"
S3_BUCKET="lnkcore"
# Required for MinIO / non-AWS providers. Set to "false" on real AWS S3.
S3_FORCE_PATH_STYLE="true"
