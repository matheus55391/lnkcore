# -----------------------------------------------------------------------------
# lnkcore — example environment file
# Copy this file to `.env` and adjust the values for your environment:
#   cp .env.example .env
# -----------------------------------------------------------------------------

# ---------- Database (PostgreSQL) ----------
# Matches the docker-compose.yml defaults for local development.
DATABASE_URL="postgresql://lnkcore:lnkcore@localhost:5432/lnkcore?schema=public"

# ---------- Better Auth ----------
# Generate a strong secret (>= 32 chars). E.g.: `openssl rand -base64 32`
BETTER_AUTH_SECRET="change-me-please-use-a-strong-32-char-secret"
# Public base URL of the app (no trailing slash).
BETTER_AUTH_URL="http://localhost:3000"
# Optional: exposed to the browser so the auth client can resolve the base URL.
# NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# ---------- Stripe ----------
# Secret key da conta Stripe (test em dev, live em produção).
STRIPE_SECRET_KEY="sk_test_change_me"
# Price ID do plano PRO (recorrente) criado no Dashboard do Stripe.
STRIPE_PRO_PRICE_ID="price_change_me"
# Secret do endpoint de webhook (/api/stripe/webhook).
# Em dev local, obtenha com:
# stripe listen --forward-to http://localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_change_me"

# ---------- Object storage (MinIO / S3-compatible) ----------
# Matches the docker-compose.yml defaults for local development.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="lnkcore"
S3_SECRET_KEY="lnkcore123"
S3_BUCKET="lnkcore"
# Required for MinIO / non-AWS providers. Set to "false" on real AWS S3.
S3_FORCE_PATH_STYLE="true"
# Optional: public-facing base URL for stored objects. Useful when the app
# runs inside Docker and S3_ENDPOINT is an internal address (e.g. http://minio:9000)
# but browsers need to reach http://localhost:9000. Defaults to S3_ENDPOINT.
# S3_PUBLIC_URL="http://localhost:9000"
